---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
import { getEntry, getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const settings = (await getEntry('settings', 'site')).data;
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);

const icons: Record<string, string> = {
  'land-survey': '<path d="M12 21s-6-5.2-6-10a6 6 0 1 1 12 0c0 4.8-6 10-6 10Z"></path><circle cx="12" cy="11" r="2.2"></circle>',
  construction: '<path d="M3 21h18M6 21V8l6-4 6 4v13M10 21v-5h4v5"></path>',
  'urban-planning': '<rect x="3" y="3" width="7" height="9" rx="1"></rect><rect x="14" y="3" width="7" height="5" rx="1"></rect><rect x="14" y="12" width="7" height="9" rx="1"></rect><rect x="3" y="16" width="7" height="5" rx="1"></rect>',
  'interior-design': '<path d="M4 18v-8a2 2 0 0 1 2-2h2v4h8V8h2a2 2 0 0 1 2 2v8"></path><path d="M2 18h20v2H2z"></path><path d="M8 8V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>',
  landscaping: '<path d="M11 20A7 7 0 0 1 4 13c0-4 3-8 8-10 5 2 8 6 8 10a7 7 0 0 1-7 7"></path><path d="M12 21V11M12 14c-1.5-1-3-1.2-4.5-1M12 12c1.3-1.4 2.8-2 4.5-2"></path>',
  'real-estate': '<path d="M15 7.5a4.5 4.5 0 1 1-6.4 6.3L3 19.4V21h1.6l5.6-5.6"></path><path d="M14.5 4 20 9.5M16 11l4-4"></path>',
};

const marqueeItems = [...settings.techStack, ...settings.techStack];
---

<Layout title="GeoSpark Onestop Solution | Spatial intelligence for Kenya" description="GeoSpark Onestop Solution: land survey, construction, urban planning, interior design, landscaping and real-estate management across Kenya." active="Home">
  <!-- ============ HERO ============ -->
  <header id="top" style="position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:140px clamp(20px,4vw,56px) 80px;overflow:hidden">
    <div style="position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:64px 64px;opacity:0.5;mask-image:radial-gradient(ellipse 90% 80% at 50% 40%,black 30%,transparent 75%)"></div>
    <div style="position:absolute;inset:-8%;animation:gsDrift 26s ease-in-out infinite">
      <svg width="100%" height="100%" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" fill="none" aria-hidden="true">
        <g stroke="var(--accent)" opacity="0.16">
          <path d="M180,120 C320,60 520,90 600,180 C680,270 640,380 520,420 C400,460 240,430 180,330 C120,230 100,170 180,120 Z" stroke-width="1.2"></path>
          <path d="M220,150 C330,100 490,125 555,195 C620,265 590,350 495,383 C400,416 275,392 225,312 C175,232 160,190 220,150 Z" stroke-width="1"></path>
          <path d="M260,180 C340,140 460,160 510,212 C560,264 540,322 470,347 C400,372 310,353 272,295 C234,237 225,210 260,180 Z" stroke-width="1"></path>
          <path d="M300,212 C355,185 430,197 464,231 C498,265 484,304 438,321 C392,338 336,325 312,287 C288,249 282,230 300,212 Z" stroke-width="0.9"></path>
        </g>
        <g stroke="var(--accent)" opacity="0.15">
          <path d="M760,430 C900,360 1080,400 1140,510 C1200,620 1140,730 990,760 C840,790 700,730 670,620 C640,510 660,480 760,430 Z" stroke-width="1.2"></path>
          <path d="M790,470 C900,415 1040,445 1090,530 C1140,615 1095,700 980,725 C865,750 755,703 730,617 C705,531 715,507 790,470 Z" stroke-width="1"></path>
          <path d="M825,510 C905,470 1005,492 1042,554 C1079,616 1046,678 962,696 C878,714 800,680 782,617 C764,554 770,537 825,510 Z" stroke-width="1"></path>
          <path d="M862,548 C917,522 986,537 1010,580 C1034,623 1012,666 954,678 C896,690 843,667 831,624 C819,581 825,566 862,548 Z" stroke-width="0.9"></path>
        </g>
        <g stroke="var(--accent)" opacity="0.1">
          <path d="M700,60 C860,10 1060,50 1130,150 C1200,250 1150,340 1010,360 C870,380 720,330 690,230 C660,130 640,80 700,60 Z" stroke-width="1"></path>
          <path d="M740,95 C870,55 1030,90 1086,170 C1142,250 1100,320 986,336 C872,352 752,312 728,232 C704,152 692,112 740,95 Z" stroke-width="0.9"></path>
        </g>
      </svg>
    </div>
    <div style="position:absolute;top:-15%;right:-8%;width:620px;height:620px;border-radius:50%;background:radial-gradient(circle,rgba(46,100,23,0.16),transparent 65%);animation:gsDrift2 20s ease-in-out infinite"></div>
    <div style="position:absolute;bottom:-20%;left:-10%;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,rgba(46,100,23,0.14),transparent 65%);animation:gsDrift2 24s ease-in-out infinite reverse"></div>

    {settings.showCoords && (
      <div class="gs-coords" style="position:absolute;inset:0;pointer-events:none;font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.14em;color:var(--muted);opacity:0.7">
        <div style="position:absolute;top:19%;left:7%;display:flex;align-items:center;gap:8px;animation:gsFloat 7s ease-in-out infinite"><span style="width:6px;height:6px;border-radius:1.5px;background:var(--emerald);animation:gsPulse 3s infinite"></span>-1.2921&deg; &middot; 36.8219&deg; NAIROBI</div>
        <div style="position:absolute;top:31%;right:9%;animation:gsFloat 9s ease-in-out infinite 1s">GRID &middot; UTM ZONE 37S</div>
        <div style="position:absolute;bottom:33%;left:11%;animation:gsFloat 8s ease-in-out infinite 2s">RTK FIX &middot; H &plusmn;8 MM <span style="animation:gsBlink 1.6s infinite">&#9646;</span></div>
        <div style="position:absolute;bottom:24%;right:13%;display:flex;align-items:center;gap:8px;animation:gsFloat 10s ease-in-out infinite .5s"><span style="width:6px;height:6px;border-radius:1.5px;background:var(--emerald)"></span>0.0236&deg; &middot; 37.9062&deg; KENYA</div>
      </div>
    )}

    <div style="position:relative;z-index:2;max-width:1180px;margin:0 auto;width:100%">
      <div data-reveal="0" style="display:inline-flex;align-items:center;gap:10px;padding:8px 16px;border-radius:999px;border:1px solid var(--line);background:var(--surface);backdrop-filter:blur(12px);font-size:12.5px;font-weight:500;color:var(--muted);margin-bottom:28px">
        <span style="width:7px;height:7px;border-radius:2px;background:var(--accent);animation:gsPulse 2.6s infinite"></span>
        {settings.heroEyebrow}
      </div>
      <h1 data-reveal="60" style="font-family:'Space Grotesk',sans-serif;font-size:clamp(46px,7.4vw,96px);line-height:1.02;letter-spacing:-0.035em;font-weight:700;margin:0 0 26px;max-width:13ch">
        {settings.heroHeadlinePlain}
        <span style="background:linear-gradient(95deg,var(--accent),var(--emerald));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent"> {settings.heroHeadlineGradient}</span>
      </h1>
      <p data-reveal="120" style="font-size:clamp(16px,1.6vw,19px);line-height:1.65;color:var(--muted);max-width:56ch;margin:0 0 38px">
        {settings.heroLead}
      </p>
      <div data-reveal="180" style="display:flex;flex-wrap:wrap;gap:14px;align-items:center;margin-bottom:64px">
        <a href="#services" data-magnetic="1" class="gs-btn-primary" style="display:inline-flex;align-items:center;gap:10px;padding:15px 30px;border-radius:999px;background:linear-gradient(120deg,var(--accent),var(--emerald));color:#fff;font-size:15px;font-weight:600;text-decoration:none;box-shadow:0 12px 32px -8px rgba(46,100,23,0.55)">
          Explore our services
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
        <a href={withBase('/contact')} data-magnetic="1" class="gs-btn-secondary" style="display:inline-flex;align-items:center;gap:10px;padding:15px 30px;border-radius:999px;border:1px solid var(--line);background:var(--surface);backdrop-filter:blur(12px);color:var(--ink);font-size:15px;font-weight:600;text-decoration:none">Contact us</a>
      </div>
      <div data-reveal="240" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:18px;overflow:hidden;max-width:820px">
        {settings.stats.map((s) => (
          <div style="background:var(--surface);backdrop-filter:blur(12px);padding:20px 24px">
            <div style="font-family:'Space Grotesk',sans-serif;font-size:32px;font-weight:700;letter-spacing:-0.02em"><span data-count={s.value} data-suffix={s.suffix}>{s.value}{s.suffix}</span></div>
            <div style="font-size:12.5px;color:var(--muted);margin-top:4px">{s.label}</div>
          </div>
        ))}
        <div style="background:var(--surface);backdrop-filter:blur(12px);padding:20px 24px">
          <div style="font-family:'Space Grotesk',sans-serif;font-size:32px;font-weight:700;letter-spacing:-0.02em">{settings.rtkAccuracy}<span style="font-size:18px;color:var(--muted)">{settings.rtkUnit}</span></div>
          <div style="font-size:12.5px;color:var(--muted);margin-top:4px">{settings.rtkLabel}</div>
        </div>
      </div>
    </div>
  </header>

  <!-- ============ SERVICES ============ -->
  <section id="services" style="position:relative;padding:110px clamp(20px,4vw,56px);max-width:1290px;margin:0 auto">
    <div data-reveal="0" style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.28em;color:var(--accent);text-transform:uppercase;margin-bottom:16px">What we do</div>
    <h2 data-reveal="60" style="font-family:'Space Grotesk',sans-serif;font-size:clamp(30px,4vw,52px);letter-spacing:-0.03em;font-weight:700;line-height:1.08;margin:0 0 14px;max-width:20ch">One partner, from boundary beacon to finished build.</h2>
    <p data-reveal="100" style="color:var(--muted);font-size:16.5px;line-height:1.65;max-width:60ch;margin:0 0 54px">Six integrated service lines that keep your project on one accountable team: surveyed, planned, built and managed.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:20px">
      {services.map((svc, i) => (
        <a href={withBase('/contact')} data-reveal={(i % 3) * 60} class="gs-svc" style="position:relative;display:block;text-decoration:none;color:var(--ink);background:var(--card);backdrop-filter:blur(16px);border:1px solid var(--line);border-radius:22px;padding:30px 28px;overflow:hidden">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:44px">
            <span style="width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,rgba(46,100,23,0.14),rgba(46,100,23,0.14));display:flex;align-items:center;justify-content:center;color:var(--accent)">
              <svg width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[svc.data.icon]} />
            </span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted)">{svc.data.number}</span>
          </div>
          <h3 style="font-family:'Space Grotesk',sans-serif;font-size:21px;font-weight:600;letter-spacing:-0.015em;margin:0 0 10px">{svc.data.title}</h3>
          <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0 0 18px">{svc.data.description}</p>
          <span style="font-size:13.5px;font-weight:600;color:var(--accent);display:inline-flex;align-items:center;gap:6px">Enquire <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ============ ABOUT / MISSION ============ -->
  <section id="about" style="position:relative;padding:110px clamp(20px,4vw,56px);overflow:hidden">
    <div style="position:absolute;inset:0;background:linear-gradient(150deg,rgba(46,100,23,0.06),rgba(46,100,23,0.07));border-top:1px solid var(--line);border-bottom:1px solid var(--line)"></div>
    <div style="position:absolute;inset:-6%;opacity:0.6;animation:gsDrift2 30s ease-in-out infinite">
      <svg width="100%" height="100%" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" fill="none" aria-hidden="true">
        <g stroke="var(--accent)" opacity="0.1">
          <path d="M-50,420 C200,300 420,480 640,380 C860,280 1020,420 1260,340" stroke-width="1.2"></path>
          <path d="M-50,470 C200,350 420,530 640,430 C860,330 1020,470 1260,390" stroke-width="1"></path>
          <path d="M-50,520 C200,400 420,580 640,480 C860,380 1020,520 1260,440" stroke-width="0.9"></path>
        </g>
      </svg>
    </div>
    <div style="position:relative;max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:56px;align-items:start">
      <div>
        <div data-reveal="0" style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.28em;color:var(--accent);text-transform:uppercase;margin-bottom:16px">Who we are</div>
        <h2 data-reveal="60" style="font-family:'Space Grotesk',sans-serif;font-size:clamp(28px,3.6vw,46px);letter-spacing:-0.03em;font-weight:700;line-height:1.1;margin:0 0 22px">Building smart, green and resilient spaces.</h2>
        <p data-reveal="100" style="color:var(--muted);font-size:16px;line-height:1.7;margin:0 0 18px"><strong style="color:var(--ink);font-weight:600">Mission:</strong> {settings.missionText}</p>
        <p data-reveal="140" style="color:var(--muted);font-size:16px;line-height:1.7;margin:0 0 34px"><strong style="color:var(--ink);font-weight:600">Vision:</strong> {settings.visionText}</p>
        <a data-reveal="180" href="#team" style="display:inline-flex;align-items:center;gap:8px;font-size:14.5px;font-weight:600;color:var(--accent);text-decoration:none">Meet the founders <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        {settings.values.map((v, i) => (
          <div data-reveal={i * 60} class="gs-value-card" style="background:var(--card);backdrop-filter:blur(16px);border:1px solid var(--line);border-radius:20px;padding:24px">
            <div style={`font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:${i % 2 === 0 ? 'var(--accent)' : 'var(--emerald)'};letter-spacing:0.18em;margin-bottom:12px`}>{String(i + 1).padStart(2, '0')}</div>
            <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:17px;margin-bottom:6px">{v.title}</div>
            <div style="font-size:13.5px;color:var(--muted);line-height:1.55">{v.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TECHNOLOGY MARQUEE ============ -->
  <section style="padding:72px 0;overflow:hidden">
    <div style="text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.28em;color:var(--muted);text-transform:uppercase;margin-bottom:34px">Field-to-finish technology</div>
    <div style="position:relative;mask-image:linear-gradient(90deg,transparent,black 12%,black 88%,transparent)">
      <div style="display:flex;gap:14px;width:max-content;animation:gsMarquee 30s linear infinite">
        {marqueeItems.map((t) => (
          <span style="padding:12px 24px;border-radius:999px;border:1px solid var(--line);background:var(--surface);backdrop-filter:blur(10px);font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:500;white-space:nowrap">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TEAM ============ -->
  <section id="team" style="padding:110px clamp(20px,4vw,56px);max-width:1290px;margin:0 auto">
    <div data-reveal="0" style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.28em;color:var(--accent);text-transform:uppercase;margin-bottom:16px">Leadership</div>
    <h2 data-reveal="60" style="font-family:'Space Grotesk',sans-serif;font-size:clamp(30px,4vw,52px);letter-spacing:-0.03em;font-weight:700;line-height:1.08;margin:0 0 54px;max-width:22ch">Surveyors, builders and financiers. One founding team.</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px">
      {team.map((member, i) => (
        <div data-reveal={i * 60} class="gs-value-card" style="background:var(--card);backdrop-filter:blur(16px);border:1px solid var(--line);border-radius:22px;padding:30px">
          <img src={withBase(member.data.photo)} alt={member.data.name} width="84" height="84" style="width:84px;height:84px;border-radius:22px;object-fit:cover;object-position:top;border:1px solid var(--line);margin-bottom:22px" />
          <h3 style="font-family:'Space Grotesk',sans-serif;font-size:20px;font-weight:600;letter-spacing:-0.015em;margin:0 0 4px">{member.data.name}</h3>
          <div style="font-size:13px;font-weight:600;color:var(--accent);margin-bottom:14px">{member.data.role}</div>
          <p style="font-size:14px;line-height:1.6;color:var(--muted);margin:0 0 16px">{member.data.bio}</p>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            {member.data.tags.map((tag) => (
              <span style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.08em;padding:5px 10px;border-radius:999px;border:1px solid var(--line);color:var(--muted)">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section style="padding:40px clamp(20px,4vw,56px) 20px;max-width:1290px;margin:0 auto">
    <div data-reveal="0" style="display:inline-flex;align-items:center;padding:8px 18px;border-radius:999px;border:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--accent);margin-bottom:26px">What clients say</div>
    <h2 data-reveal="0" style="font-family:'Space Grotesk',sans-serif;font-size:clamp(30px,4.4vw,56px);letter-spacing:-0.03em;font-weight:700;line-height:1.05;color:var(--ink);margin:0 0 clamp(36px,4vw,56px);max-width:16ch">Trusted by people building on the ground.</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(20px,2.4vw,32px)">
      {testimonials.map((t, i) => (
        <figure data-reveal={i * 60} class="gs-tcard" style="margin:0;display:flex;flex-direction:column;background:var(--card);backdrop-filter:blur(16px);border:1px solid var(--ink);border-radius:20px;padding:clamp(28px,3vw,38px);box-shadow:7px 7px 0 var(--accent)">
          <blockquote style="margin:0;font-size:clamp(17px,1.4vw,19px);line-height:1.55;color:var(--ink)">&ldquo;{t.data.quote}&rdquo;</blockquote>
          <hr style="border:none;border-top:1px solid var(--line);margin:26px 0 20px" />
          <figcaption style="font-family:'IBM Plex Mono',monospace"><span style="display:block;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink);font-weight:600">{t.data.name}</span><span style="display:block;font-size:13px;color:var(--muted);margin-top:4px">{t.data.subtitle}</span></figcaption>
        </figure>
      ))}
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
