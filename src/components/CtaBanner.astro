---
import { getEntry } from 'astro:content';
import { withBase } from '../lib/url';

const settings = (await getEntry('settings', 'site')).data;
---

<style>
  @keyframes gsCtaDrift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-26px, 16px) rotate(-1deg); }
  }
  @keyframes gsCtaBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }
</style>

<section style="padding:40px clamp(20px,4vw,56px) 110px;max-width:1290px;margin:0 auto;font-family:'Instrument Sans',system-ui,sans-serif;box-sizing:border-box">
  <div style="position:relative;border-radius:30px;overflow:hidden;padding:clamp(40px,5.5vw,72px) clamp(28px,5vw,64px);background:linear-gradient(135deg,#14260D,#0B1233);border:1px solid rgba(255,255,255,0.08)">
    <div style="position:absolute;inset:-10%;animation:gsCtaDrift 28s ease-in-out infinite">
      <svg width="100%" height="100%" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice" fill="none" aria-hidden="true">
        <g stroke="#5C7CFF" opacity="0.2">
          <path d="M100,250 C300,120 500,380 700,250 C900,120 1050,340 1250,220" stroke-width="1.2"></path>
          <path d="M80,310 C280,180 480,440 680,310 C880,180 1030,400 1230,280" stroke-width="1"></path>
          <path d="M60,370 C260,240 460,500 660,370 C860,240 1010,460 1210,340" stroke-width="0.9"></path>
        </g>
        <g stroke="#7FBF4D" opacity="0.16">
          <path d="M120,190 C320,60 520,320 720,190 C920,60 1070,280 1270,160" stroke-width="1"></path>
        </g>
      </svg>
    </div>
    <div style="position:absolute;top:-34%;right:-6%;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(92,124,255,0.28),transparent 65%)"></div>
    <div style="position:relative;display:grid;grid-template-columns:1.15fr 0.85fr;gap:clamp(36px,5vw,72px);align-items:center" class="gs-cta-grid">
      <div>
        <div style="display:inline-flex;align-items:center;gap:9px;padding:7px 14px;border-radius:999px;border:1px solid rgba(127,191,77,0.35);background:rgba(127,191,77,0.1);margin-bottom:22px">
          <span style="width:8px;height:8px;border-radius:50%;background:#7FBF4D;animation:gsCtaBlink 2s ease-in-out infinite"></span>
          <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#B8D89A">{settings.ctaBadge}</span>
        </div>
        <h2 style="font-family:'Space Grotesk',sans-serif;font-size:clamp(32px,4.4vw,58px);letter-spacing:-0.03em;font-weight:700;line-height:1.04;color:#fff;margin:0 0 18px">{settings.ctaHeadlinePlain}<br><span style="background:linear-gradient(95deg,#7FBF4D,#5C7CFF);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent">{settings.ctaHeadlineGradient}</span></h2>
        <p style="color:rgba(233,241,246,0.65);font-size:16.5px;line-height:1.65;max-width:46ch;margin:0 0 30px">{settings.ctaSubcopy}</p>
        <a href={withBase('/contact')} class="gs-cta-btn" data-magnetic="1" style="display:inline-flex;align-items:center;gap:11px;padding:16px 32px;border-radius:999px;background:linear-gradient(120deg,#7FBF4D,#5C7CFF);color:#04121c;font-size:15px;font-weight:700;text-decoration:none;box-shadow:0 14px 36px -8px rgba(127,191,77,0.4)">Start your project<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <a href={`mailto:${settings.email}`} class="gs-cta-card" style="display:flex;align-items:center;gap:16px;padding:18px 20px;border-radius:16px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);backdrop-filter:blur(12px);text-decoration:none;color:#fff">
          <span style="flex-shrink:0;width:42px;height:42px;border-radius:12px;background:rgba(127,191,77,0.16);display:flex;align-items:center;justify-content:center;color:#9FD16B"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg></span>
          <span style="display:flex;flex-direction:column;gap:2px;min-width:0">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(233,241,246,0.5)">Email us</span>
            <span style="font-size:15px;font-weight:600">{settings.email}</span>
          </span>
        </a>
        <a href={`tel:${settings.phone.replace(/\s+/g, '')}`} class="gs-cta-card" style="display:flex;align-items:center;gap:16px;padding:18px 20px;border-radius:16px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);backdrop-filter:blur(12px);text-decoration:none;color:#fff">
          <span style="flex-shrink:0;width:42px;height:42px;border-radius:12px;background:rgba(92,124,255,0.18);display:flex;align-items:center;justify-content:center;color:#9DB2FF"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2Z"></path></svg></span>
          <span style="display:flex;flex-direction:column;gap:2px;min-width:0">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(233,241,246,0.5)">Call us</span>
            <span style="font-size:15px;font-weight:600">{settings.phone}</span>
          </span>
        </a>
        <div style="display:flex;align-items:center;gap:16px;padding:18px 20px;border-radius:16px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);backdrop-filter:blur(12px);color:#fff">
          <span style="flex-shrink:0;width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;color:rgba(233,241,246,0.8)"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg></span>
          <span style="display:flex;flex-direction:column;gap:2px;min-width:0">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(233,241,246,0.5)">Response time</span>
            <span style="font-size:15px;font-weight:600">Within one working day</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
