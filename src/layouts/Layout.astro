---
import { getEntry } from 'astro:content';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description: string;
  active: 'Home' | 'Services' | 'Projects' | 'About' | 'Contact';
  showCta?: boolean;
}

const { title, description, active, showCta = true } = Astro.props;
const settings = (await getEntry('settings', 'site')).data;

// Each brand accent has a lightened dark-theme variant for contrast.
const accentDark: Record<string, string> = {
  '#2E6417': '#7FBF4D',
  '#0025CC': '#5C7CFF',
  '#7FBF4D': '#9BE05A',
};
const accentLight = settings.accent;
const accentDarkValue = accentDark[settings.accent] ?? '#7FBF4D';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={withBase('/assets/logo-full.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style set:html={`html:root{--accent:${accentLight};--glow:${settings.glow}}html:root[data-theme="dark"]{--accent:${accentDarkValue}}`}></style>
    <script is:inline>
      // Set theme before paint to avoid a flash of the wrong theme.
      (function () {
        var saved = null;
        try { saved = localStorage.getItem('gs-theme'); } catch (e) {}
        document.documentElement.dataset.theme = saved === 'dark' ? 'dark' : 'light';
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <div id="gs-veil" class="gs-veil" aria-hidden="true" style="position:fixed;inset:0;z-index:99999;pointer-events:none;background:var(--bg)"></div>
    <div id="gs-light" style={`position:fixed;inset:0;pointer-events:none;z-index:1;opacity:${settings.glow};transition:opacity .4s ease`}></div>

    <Nav active={active} showCta={showCta} />

    <slot />

    <script
      is:inline
      define:vars={{ cardHoverStyle: settings.cardHoverStyle }}
    >
      (function () {
        var svc = document.getElementById('services');
        if (svc) svc.dataset.cardhover = cardHoverStyle;

        // --- page transition veil ---
        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
          if (!a) return;
          var href = a.getAttribute('href') || '';
          if (/^https?:/.test(href) || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('#')) return;
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || a.getAttribute('target') === '_blank') return;
          if (a.hostname && a.hostname !== location.hostname) return;
          e.preventDefault();
          var v = document.getElementById('gs-veil');
          if (!v) { location.href = href; return; }
          v.style.animation = 'none';
          v.style.transition = 'none';
          v.style.visibility = 'visible';
          v.style.opacity = '0';
          void v.offsetHeight;
          v.style.transition = 'opacity .28s ease';
          v.style.opacity = '1';
          setTimeout(function () { location.href = href; }, 320);
        }, true);
        window.addEventListener('pageshow', function (e) {
          if (!e.persisted) return;
          var v = document.getElementById('gs-veil');
          if (v) { v.style.transition = 'none'; v.style.animation = 'none'; v.style.opacity = '0'; v.style.visibility = 'hidden'; }
        });

        // --- scroll reveals ---
        var reveals = Array.prototype.slice.call(document.querySelectorAll('[data-reveal]'));
        var vh = window.innerHeight;
        var toObserve = [];
        reveals.forEach(function (el) {
          var r = el.getBoundingClientRect();
          if (r.top > vh * 0.88) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(26px)';
            toObserve.push(el);
          }
        });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (!en.isIntersecting) return;
            var el = en.target;
            var delay = parseInt(el.dataset.reveal || '0', 10);
            el.style.transition = 'opacity .8s ease ' + delay + 'ms, transform .8s cubic-bezier(.22,1,.36,1) ' + delay + 'ms';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            io.unobserve(el);
          });
        }, { threshold: 0.12 });
        toObserve.forEach(function (el) { io.observe(el); });

        // --- animated counters ---
        var counters = Array.prototype.slice.call(document.querySelectorAll('[data-count]'));
        var cio = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (!en.isIntersecting) return;
            var el = en.target;
            cio.unobserve(el);
            var target = parseFloat(el.dataset.count);
            var suffix = el.dataset.suffix || '';
            var t0 = performance.now();
            var dur = 1500;
            function tick(now) {
              var p = Math.min(1, (now - t0) / dur);
              var eased = 1 - Math.pow(1 - p, 3);
              el.textContent = Math.round(target * eased) + suffix;
              if (p < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          });
        }, { threshold: 0.5 });
        counters.forEach(function (el) { cio.observe(el); });

        // --- sticky nav shadow on scroll ---
        var nav = document.getElementById('gs-nav');
        function onScroll() {
          if (!nav) return;
          nav.style.boxShadow = window.scrollY > 24
            ? '0 16px 40px -16px rgba(20,29,18,0.34)'
            : '0 8px 24px -14px rgba(20,29,18,0.22)';
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // --- mouse-responsive lighting ---
        var light = document.getElementById('gs-light');
        var raf = 0, mx = window.innerWidth / 2, my = window.innerHeight / 3;
        function paint() {
          raf = 0;
          if (!light) return;
          var dark = document.documentElement.dataset.theme === 'dark';
          var a = dark ? 0.13 : 0.09;
          light.style.background = 'radial-gradient(600px circle at ' + mx + 'px ' + my + 'px, rgba(46,100,23,' + a + '), transparent 70%)';
        }
        window.addEventListener('mousemove', function (e) {
          mx = e.clientX; my = e.clientY;
          if (!raf) raf = requestAnimationFrame(paint);
        }, { passive: true });
        paint();

        // --- magnetic buttons ---
        document.querySelectorAll('[data-magnetic]').forEach(function (btn) {
          btn.addEventListener('mousemove', function (e) {
            var r = btn.getBoundingClientRect();
            var dx = e.clientX - (r.left + r.width / 2);
            var dy = e.clientY - (r.top + r.height / 2);
            btn.style.transform = 'translate(' + dx * 0.18 + 'px,' + dy * 0.22 + 'px)';
          });
          btn.addEventListener('mouseleave', function () {
            btn.style.transition = 'transform .5s cubic-bezier(.22,1,.36,1), box-shadow .3s ease';
            btn.style.transform = 'translate(0,0)';
            setTimeout(function () { btn.style.transition = 'box-shadow .3s ease'; }, 500);
          });
        });

        // --- per-card spotlight tracking (used by Spotlight hover mode) ---
        document.querySelectorAll('.gs-svc').forEach(function (card) {
          card.addEventListener('mousemove', function (e) {
            var r = card.getBoundingClientRect();
            card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
            card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
          });
        });

        // --- theme toggle button ---
        var themeBtn = document.getElementById('gs-theme-toggle');
        if (themeBtn) {
          themeBtn.addEventListener('click', function () {
            var next = document.documentElement.dataset.theme !== 'dark';
            document.documentElement.dataset.theme = next ? 'dark' : 'light';
            try { localStorage.setItem('gs-theme', next ? 'dark' : 'light'); } catch (e) {}
            document.querySelectorAll('[data-theme-icon]').forEach(function (el) {
              el.style.display = (el.dataset.themeIcon === (next ? 'sun' : 'moon')) ? 'flex' : 'none';
            });
            onScroll();
          });
        }

        // --- mobile menu toggle ---
        var burger = document.getElementById('gs-burger');
        var menu = document.getElementById('gs-mobile-menu');
        if (burger && menu) {
          burger.addEventListener('click', function () {
            menu.style.display = menu.style.display === 'flex' ? 'none' : 'flex';
          });
          menu.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', function () { menu.style.display = 'none'; });
          });
        }

        // apply initial icon visibility based on saved theme
        var dark0 = document.documentElement.dataset.theme === 'dark';
        document.querySelectorAll('[data-theme-icon]').forEach(function (el) {
          el.style.display = (el.dataset.themeIcon === (dark0 ? 'sun' : 'moon')) ? 'flex' : 'none';
        });
      })();
    </script>
  </body>
</html>
